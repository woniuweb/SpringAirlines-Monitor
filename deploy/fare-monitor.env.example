# Copy to deploy/fare-monitor.env on Linux and adjust the values below.

FARE_MONITOR_SMTP_PASSWORD=replace-with-your-app-password

# Optional overrides for deploy/run_daily_report.sh
# APP_ROOT=/opt/fare-monitor/app
# RUNTIME_ROOT=/opt/fare-monitor/runtime
# VENV_PATH=/opt/fare-monitor/app/.venv
# CONFIG_PATH=/opt/fare-monitor/app/fare-monitor.toml
# ENV_FILE=/opt/fare-monitor/app/deploy/fare-monitor.env
# SCAN_DAYS=180
